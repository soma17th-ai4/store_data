# OpenAI
OPENAI_API_KEY=your-upstage-api-key
OPENAI_BASE_URL=https://api.upstage.ai/v1
# 문서/본문을 저장용 embedding으로 만들 때는 passage 모델을 씁니다.
OPENAI_EMBEDDING_MODEL=solar-embedding-1-large-passage
# 나중에 사용자 검색 질문을 embedding할 때는 query 모델을 씁니다.
OPENAI_QUERY_EMBEDDING_MODEL=solar-embedding-1-large-query
# desc_v1이 없는 문서의 일반 고객용 한 문장 설명 생성 모델입니다.
OPENAI_DESC_MODEL=solar-mini-250422
# Upstage Solar embedding에는 dimensions/encoding_format을 기본적으로 보내지 않습니다.
OPENAI_EMBEDDING_DIMENSIONS=
OPENAI_EMBEDDING_ENCODING_FORMAT=

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=20060
MONGO_USERNAME=root
MONGO_PASSWORD=change-me
MONGO_AUTH_SOURCE=admin
MONGO_DB=crawler_db
MONGO_COLLECTION=kipris_patents

# Embedding source/target fields
SOURCE_TEXT_FIELD=desc_v1
TARGET_EMBEDDING_FIELD=embedded_v2

#SUPABASE
SUPABASE_URL=supabase_url
SUPABASE_KEY=supabase_key
SUPABASE_TABLE=patents
SUPABASE_BATCH_SIZE=100


# Runtime defaults
BATCH_SIZE=64
DESC_WORKERS=5
MONGO_PAGE_SIZE=500
OPENAI_MAX_RETRIES=5
